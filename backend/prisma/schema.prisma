datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

model User {
  id            String   @id @default(cuid())
  clerkId       String?  @unique
  username      String   @unique
  fullName      String?
  email         String?  @unique
  passwordHash  String?
  tokens        Int      @default(500)
  eloJS         Int      @default(1000)
  eloPython     Int      @default(1000)
  eloJava       Int      @default(1000)
  eloUIUX       Int      @default(1000)
  totalWins     Int      @default(0)
  totalDuels    Int      @default(0)
  currentStreak Int      @default(0)
  bestStreak    Int      @default(0)
  rank          String   @default("Bug Hunter")
  xp            Int      @default(0)
  level         Int      @default(1)
  lastDailyClaim DateTime?
  dailyStreak     Int      @default(0)
  createdAt     DateTime @default(now())
  duels         DuelParticipant[]
  kbcSoloRuns   KbcSoloRun[]
  dailyChallengeRuns DailyChallengeRun[]
  achievements  UserAchievement[]
  quests        UserQuest[]
  
  friendKey     String   @unique @default(cuid())
  friends       Friendship[] @relation("UserFriends")
  friendOf      Friendship[] @relation("FriendUsers")
}

model Bug {
  id          String   @id @default(cuid())
  language    String   // "javascript" | "python" | "java"
  difficulty  String   // "easy" | "medium" | "hard"
  title       String
  brokenCode  String
  fixedCode   String
  explanation String
  category    String   // "logic" | "syntax" | "runtime" | "off-by-one" | "null-ref" | "async"
  createdAt   DateTime @default(now())
  duels       Duel[]
}

model Duel {
  id           String   @id @default(cuid())
  gameType     String   @default("debug") // "debug" | "color_match"
  bugId        String?
  bug          Bug?     @relation(fields: [bugId], references: [id])
  status       String   @default("waiting") // "waiting" | "active" | "completed"
  betAmount    Int      @default(50)
  winnerId     String?
  language     String?
  difficulty   String?
  targetColor  String?  // for color matching game e.g., "rgb(120, 80, 200)"
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime @default(now())
  participants DuelParticipant[]
}

model DuelParticipant {
  id              String   @id @default(cuid())
  duelId          String
  duel            Duel     @relation(fields: [duelId], references: [id])
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  submittedCode   String?
  explanation     String?
  submittedColor  String?  // for color matching game e.g., "rgb(120, 85, 195)"
  colorScore      Int?     // score out of 1000
  submitTime      Int?     // seconds from duel start
  explanationScore Int?    // 0-20, AI judged
  isWinner        Boolean  @default(false)
  progressPercent Int      @default(0) // for FOMO signals
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  user      User     @relation("UserFriends", fields: [userId], references: [id])
  friend    User     @relation("FriendUsers", fields: [friendId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, friendId])
}

model KbcSoloRun {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  questionsAnswered Int
  accuracy          Float
  fastestAnswerTime Int
  averageAnswerTime Float    @default(0)
  lifelinesUsed     String
  prizeEarned       Int
  createdAt         DateTime @default(now())
}

model DailyChallenge {
  id        String   @id @default(cuid())
  date      String   @unique // "YYYY-MM-DD"
  questions String   // JSON array of 15 questions
  createdAt DateTime @default(now())
}

model DailyChallengeRun {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  date             String   // "YYYY-MM-DD"
  questionsCleared Int
  timeTaken        Float
  prizeEarned      Int
  createdAt        DateTime @default(now())

  @@unique([userId, date])
}

model Achievement {
  id           String            @id
  title        String
  description  String
  icon         String
  rarity       String            // "Common" | "Rare" | "Epic" | "Legendary"
  category     String            // "Combat" | "Streak" | "Progression" | "KBC" | "Consistency" | "Social" | "Special"
  xpReward     Int
  tokenReward  Int
  users        UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id])
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
}

model Quest {
  id            String      @id
  title         String
  description   String
  type          String      // e.g. "win_duel", "play_duel", "play_kbc", "win_kbc", "earn_tokens", "claim_daily_reward", "gain_xp", "add_friend"
  target        Int
  rewardXP      Int
  rewardTokens  Int
  category      String      // "DAILY" | "WEEKLY"
  userQuests    UserQuest[]
}

model UserQuest {
  id            String    @id @default(cuid())
  userId        String
  questId       String
  progress      Int       @default(0)
  completed     Boolean   @default(false)
  claimed       Boolean   @default(false)
  completedAt   DateTime?
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id])
  quest         Quest     @relation(fields: [questId], references: [id])

  @@unique([userId, questId, expiresAt])
}
